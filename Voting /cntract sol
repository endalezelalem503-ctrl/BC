pragma solidity ^0.8.0;

contract Ownable {
    address public owner;

    constructor() {
        owner = msg.sender;
    }
}

contract Transferable is Ownable {

    function transfer(address newOwner) public {
        require(msg.sender == owner, "Only owner can transfer");
        owner = newOwner;
    }
}

contract Collectible is Transferable {

}
